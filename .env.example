APP_NAME="Transcoding Webservice"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://transcoding-webservice.internal

APP_IMAGE_TAG=local
HTTP_BIND=127.0.0.1:8080

LOG_CHANNEL=stack

SECURITY_SOURCE_URL_ALLOWLIST_ENABLED=false
SECURITY_SOURCE_URL_ALLOWED_HOSTS=
SECURITY_SOURCE_URL_ALLOW_USER_HOST=true
SECURITY_DOWNLOAD_TIMEOUT_SECONDS=300
SECURITY_DOWNLOAD_CONNECT_TIMEOUT_SECONDS=10
SECURITY_DOWNLOAD_MAX_BYTES=0
SECURITY_LOG_SCRUBBING_ENABLED=true
ADMIN_UPLOADS_ENABLED=false

DB_CONNECTION=mysql
DB_HOST=db.internal
DB_PORT=3306
DB_DATABASE=transcoding_webservice
DB_USERNAME=transcoding_webservice
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=redis
QUEUE_RETRY_AFTER=90000
QUEUE_REDIS_BLOCK_FOR=5
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

HEALTH_WORKER_STALE_AFTER_SECONDS=300
HEALTH_REDIS_REQUIRED=true

FFMPEG_BINARIES=ffmpeg
FFPROBE_BINARIES=ffprobe
CUDA_IMAGE=nvidia/cuda:13.3.0-base-ubuntu24.04
FFMPEG_SMOKE_DURATION=2
FFMPEG_SMOKE_SIZE=1280x720
FFMPEG_SMOKE_RATE=30

WORKER_HEARTBEAT_ENABLED=true
WORKER_DOWNLOAD_QUEUE=download
WORKER_DOWNLOAD_SLEEP=3
WORKER_DOWNLOAD_TRIES=3
WORKER_DOWNLOAD_MEMORY=768
WORKER_DOWNLOAD_TIMEOUT=84600
WORKER_VIDEO_QUEUE=video
WORKER_VIDEO_SLEEP=5
WORKER_VIDEO_TRIES=2
WORKER_VIDEO_MEMORY=1024
WORKER_VIDEO_TIMEOUT=84600

NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility,video
NVIDIA_SMI_BINARY=nvidia-smi
GPU_DEVICE_COUNT=1
GPU_GUARD_ENABLED=false
GPU_GUARD_MIN_FREE_MB=12288
GPU_GUARD_RETRY_DELAY_SECONDS=60
GPU_GUARD_COMMAND_TIMEOUT_SECONDS=5
GPU_GUARD_FAIL_OPEN=false

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
